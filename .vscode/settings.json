h\\(r'<meta\\[\\^>\\]\\+property=\\[\"\\\\'\\]og:image\\[\"\\\\'\\]\\[\\^>\\]\\+content=\\[\"\\\\'\\]\\(\\[\\^\"\\\\'\\]\\+\\)\\[\"\\\\'\\]', text\\)\n            if m2:\n                img=m2\\.group\\(1\\)\n        if img:\n            if img\\.startswith\\('//'\\):\n                img='https:'\\+img\n            entries\\[idx\\]\\['Image'\\]=img\n            found\\+=1\n            examples_found\\.append\\(\\{'index':idx,'Title':e\\.get\\('Title'\\),'ISBN':isbn,'Image':img,'GOODREADS':final_url\\}\\)\n        else:\n            examples_failed\\.append\\(\\{'index':idx,'Title':e\\.get\\('Title'\\),'ISBN':isbn,'GOODREADS':final_url,'reason':'no_image'\\}\\)\n    except Exception as exc:\n        errors\\+=1\n        examples_failed\\.append\\(\\{'index':idx,'Title':e\\.get\\('Title'\\),'ISBN':isbn,'GOODREADS':gr,'error':str\\(exc\\)\\}\\)\n    time\\.sleep\\(1\\.0\\)\n# write back\nopen\\(bookfile,'w',encoding='utf-8'\\)\\.write\\(json\\.dumps\\(entries,indent=2,ensure_ascii=False\\)\\)\nreport=\\{'attempted':attempted,'found':found,'errors':errors,'examples_found':examples_found,'examples_failed':examples_failed\\}\nopen\\(p/'goodreads_isbn_sample_report\\.json','w',encoding='utf-8'\\)\\.write\\(json\\.dumps\\(report,indent=2,ensure_ascii=False\\)\\)\nprint\\('Done:',attempted,'attempted,',found,'found,',errors,'errors'\\)\nPY$/": {
