{
  "name": "mybookshelf",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^13.5.0",
    "axios": "^1.18.0",
    "better-sqlite3": "^12.11.1",
    "bootstrap": "^5.3.8",
    "cheerio": "^1.2.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "jimp": "^1.6.1",
    "puppeteer": "^25.1.0",
    "react": "^19.2.7",
    "react-bootstrap": "^2.10.10",
    "react-dom": "^19.2.7",
    "react-scripts": "5.0.1",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "react-scripts start",
    "server": "node server.js",
    "dev": "concurrently \"npm run server\" \"npm start\"",
    "build": "react-scripts build",
    "precompute:pcversion": "node scripts/precompute_pc_version.js --limit=50",
    "precompute:pcversion:apply": "node scripts/precompute_pc_version.js --limit=50 --apply",
    "precompute:pcversion:all": "node scripts/precompute_pc_version.js --all --apply",
    "authors:sample": "node scripts/build_author_objects.js --limit=50",
    "authors:all": "node scripts/build_author_objects.js --all",
    "authors:merge": "node scripts/merge_duplicate_authors.js",
    "pagination:sample": "node scripts/fill_missing_pagination.js --limit=50 --apply",
    "pagination:all": "node scripts/fill_missing_pagination.js --all --apply",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "proxy": "http://localhost:4000",
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
